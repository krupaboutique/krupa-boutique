function buildDays(month, year) {
const days = [];
const total = new Date(year, month + 1, 0).getDate();
let mc = 0, wc = 0, fc = 0;
const base = month * 4;
for (let d = 1; d <= total; d++) {
const dow = new Date(year, month, d).getDay();
const key = `${month+1}-${d}`;
const fest = FESTIVALS[key];
const dateStr = `${DAY_NAMES[dow]}, ${d} ${MONTH_NAMES[month]} ${year}`;
const a = INFO.address, p = INFO.phoneDisplay;
let entry = null;
if (fest) {
let text = fest.type === “festival” ? festivalText(fest, d)
: fest.type === “anniversary” ? anniversaryText(fest.name)
: leadText(fest.name);
entry = { date:dateStr, d, month, year, occasion:fest.name, emoji:fest.emoji, type:fest.type, text, platform: fest.type===“lead” ? “WhatsApp + Instagram + Google” : “Google + Instagram + Facebook” };
} else if (dow === 1) {
const w = OFFERS[(base + mc) % OFFERS.length]; mc++;
entry = { date:dateStr, d, month, year, occasion:w.title, emoji:“🏷️”, type:“offer”, text:`${w.title}\n\n${w.body}\n\n📍 ${a}\n📞 ${p}`, platform:“Google + Instagram” };
} else if (dow === 3) {
const w = CONTENTS[(base + wc) % CONTENTS.length]; wc++;
entry = { date:dateStr, d, month, year, occasion:w.title, emoji:“💎”, type:“content”, text:`${w.title}\n\n${w.body}\n\n📍 ${a}\n📞 ${p}`, platform:“Google + Facebook” };
} else if (dow === 5) {
const w = LEADS[(base + fc) % LEADS.length]; fc++;
entry = { date:dateStr, d, month, year, occasion:w.title, emoji:“🎯”, type:“lead”, text:`${w.title}\n\n${w.body}\n\n📍 ${a}\n📞 ${p}`, platform:“WhatsApp + Instagram” };
} else if (d === 1) {
const mi = MONTH_INTROS[month];
entry = { date:dateStr, d, month, year, occasion:`${mi.mood} — ${MONTH_NAMES[month]}`, emoji:“🌟”, type:“offer”, text:`🌟 HELLO ${MONTH_NAMES[month].toUpperCase()} ${year}!\n\n${mi.mood}\n${mi.tip}\n\nKrupa Boutique is ready with:\n✅ New ${MONTH_NAMES[month]} fabric collection\n✅ Special stitching packages\n✅ Festival & event bookings open!\n\n📞 Book TODAY: ${p}\n📍 ${a}`, platform:“Google + Instagram + WhatsApp” };
}
if (entry) days.push(entry);
}
return days;
}

// ── CANVAS IMAGE DRAW ──
function rrect(ctx, x, y, w, h, r) {
r = Math.min(r, w/2, h/2);
ctx.beginPath();
ctx.moveTo(x+r,y); ctx.lineTo(x+w-r,y); ctx.quadraticCurveTo(x+w,y,x+w,y+r);
ctx.lineTo(x+w,y+h-r); ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
ctx.lineTo(x+r,y+h); ctx.quadraticCurveTo(x,y+h,x,y+h-r);
ctx.lineTo(x,y+r); ctx.quadraticCurveTo(x,y,x+r,y);
ctx.closePath();
}
function wrapLines(ctx, text, maxW) {
const out = [];
for (const para of text.split(”\n”)) {
if (!para.trim()) { out.push(””); continue; }
const words = para.split(” “); let line = “”;
for (const w of words) {
const t = line ? line + “ “ + w : w;
if (ctx.measureText(t).width > maxW && line) { out.push(line); line = w; } else line = t;
}
if (line) out.push(line);
}
return out;
}

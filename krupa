}

const PALETTE = {
festival:    [”#0d0020”,”#3b001a”,”#E91E8C”,”#FFD700”],
offer:       [”#1a0800”,”#3b1500”,”#FF8C00”,”#FFD700”],
lead:        [”#001a0d”,”#003320”,”#4CAF50”,”#FFD700”],
anniversary: [”#0a0a1a”,”#0d0d2e”,”#90CAF9”,”#FFD700”],
content:     [”#001520”,”#002535”,”#00BCD4”,”#FFD700”],
};
function drawImage(canvas, day) {
const W=1080, H=1080;
canvas.width=W; canvas.height=H;
const ctx = canvas.getContext(“2d”);
const [bg1,bg2,accent,gold] = PALETTE[day.type] || PALETTE.content;
const layout = ((day.d * 3 + day.month * 7)) % 5;

// Background
const bg = ctx.createRadialGradient(W/2,H/2,60,W/2,H/2,720);
bg.addColorStop(0, bg2); bg.addColorStop(1, bg1);
ctx.fillStyle = bg; ctx.fillRect(0,0,W,H);

// Subtle dot texture
ctx.fillStyle = “rgba(255,255,255,0.04)”;
for(let i=50;i<W;i+=55) for(let j=50;j<H;j+=55) { ctx.beginPath(); ctx.arc(i,j,1.5,0,Math.PI*2); ctx.fill(); }

// Layout variations
if (layout === 0) {
// Left-aligned split
const rp = ctx.createLinearGradient(W*0.65,0,W,0);
rp.addColorStop(0,“rgba(255,255,255,0)”); rp.addColorStop(1,“rgba(255,255,255,0.04)”);
ctx.fillStyle=rp; ctx.fillRect(W*0.65,0,W*0.35,H);
ctx.strokeStyle=gold; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(W*0.65,60); ctx.lineTo(W*0.65,H-60); ctx.stroke();
} else if (layout === 1) {
// Radial glow top
const gl = ctx.createRadialGradient(W/2,0,0,W/2,0,500);
gl.addColorStop(0,“rgba(255,255,255,0.06)”); gl.addColorStop(1,“rgba(255,255,255,0)”);
ctx.fillStyle=gl; ctx.fillRect(0,0,W,500);
} else if (layout === 2) {
// Corner glow
const gl = ctx.createRadialGradient(0,0,0,0,0,400);
gl.addColorStop(0,“rgba(255,255,255,0.05)”); gl.addColorStop(1,“rgba(0,0,0,0)”);
ctx.fillStyle=gl; ctx.fillRect(0,0,W,H);
} else if (layout === 3) {
// Bottom glow
const gl = ctx.createRadialGradient(W/2,H,0,W/2,H,500);
gl.addColorStop(0,“rgba(255,255,255,0.05)”); gl.addColorStop(1,“rgba(0,0,0,0)”);
ctx.fillStyle=gl; ctx.fillRect(0,H/2,W,H/2);
} else {
// Diagonal band
const gl = ctx.createLinearGradient(0,0,W,H);
gl.addColorStop(0,“rgba(255,255,255,0)”); gl.addColorStop(0.5,“rgba(255,255,255,0.04)”); gl.addColorStop(1,“rgba(255,255,255,0)”);
ctx.fillStyle=gl; ctx.fillRect(0,0,W,H);
}

// Outer gold border
const grd = ctx.createLinearGradient(0,0,W,H);
grd.addColorStop(0,gold); grd.addColorStop(0.5,”#FFFDE7”); grd.addColorStop(1,gold);
ctx.strokeStyle=grd; ctx.lineWidth=12; rrect(ctx,14,14,W-28,H-28,20); ctx.stroke();
ctx.strokeStyle=accent+“66”; ctx.lineWidth=2; rrect(ctx,26,26,W-52,H-52,14); ctx.stroke();

// Header panel
ctx.fillStyle=“rgba(0,0,0,0.7)”; rrect(ctx,46,46,W-92,155,18); ctx.fill();
const hl=ctx.createLinearGradient(60,0,W-60,0);
hl.addColorStop(0,“transparent”); hl.addColorStop(0.3,gold); hl.addColorStop(0.7,gold); hl.addColorStop(1,“transparent”);
ctx.strokeStyle=hl; ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(60,48); ctx.lineTo(W-60,48); ctx.stroke();
ctx.beginPath(); ctx.moveTo(60,199); ctx.lineTo(W-60,199); ctx.stroke();

ctx.fillStyle=gold; ctx.font=“bold 60px Georgia”; ctx.textAlign=“center”;
ctx.shadowColor=gold; ctx.shadowBlur=16;
ctx.fillText(“✨ Krupa Boutique”, W/2, 122); ctx.shadowBlur=0;
ctx.fillStyle=accent; ctx.font=“italic 24px Georgia”;
ctx.fillText(“Est.”+INFO.since+”  •  Kudasan, Gandhinagar  •  ⭐ “+INFO.rating, W/2, 170);

// Occasion badge
ctx.fillStyle=gold; ctx.font=“bold 26px sans-serif”; ctx.textAlign=“center”;
const occ = day.occasion.length>44 ? day.occasion.substring(0,44)+”…” : day.occasion;
ctx.fillText(occ, W/2, 238);
ctx.fillStyle=“rgba(255,255,255,0.55)”; ctx.font=“20px sans-serif”;
ctx.fillText(“📅 “+day.date, W/2, 272);

// Divider
const dl=ctx.createLinearGradient(80,0,W-80,0);
dl.addColorStop(0,“transparent”); dl.addColorStop(0.2,accent); dl.addColorStop(0.8,accent); dl.addColorStop(1,“transparent”);
ctx.strokeStyle=dl; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(80,288); ctx.lineTo(W-288,288); ctx.stroke();

// Body text
ctx.fillStyle=”#F5F5F5”; ctx.font=“33px Georgia”; ctx.textAlign=“left”;
ctx.shadowColor=“rgba(0,0,0,0.7)”; ctx.shadowBlur=5;
const lines = wrapLines(ctx, day.text, W-260);
let y=334, lh=52;
for(let i=0;i<lines.length&&y<H-215;i++) { ctx.fillText(lines[i],130,y); y+=lh; }
ctx.shadowBlur=0;

drawFooter(ctx, W, H);
}

